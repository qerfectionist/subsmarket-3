{
  "name": "subsmarket-3",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "npm --prefix frontend run build",
    "test:ui": "npm --prefix frontend run test:ui",
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "node scripts/dev-backend.mjs",
    "backend:compile": "node scripts/run-python.mjs -m compileall -q backend/src backend/tests",
    "backend:test": "node scripts/run-python.mjs -m pytest backend/tests",
    "backend:test:postgres": "node scripts/run-postgres-tests.mjs",
    "backend:lint": "node scripts/run-python.mjs -m ruff check backend/src backend/alembic backend/tests",
    "sentry:smoke": "node scripts/run-python.mjs -m subsmarket.ops.sentry_smoke",
    "telegram:smoke": "node scripts/run-python.mjs -m subsmarket.ops.telegram_production_smoke",
    "production:smoke": "node scripts/run-python.mjs -m subsmarket.ops.production_smoke",
    "production:load-smoke": "node scripts/run-python.mjs -m subsmarket.ops.load_smoke",
    "production:check": "node scripts/production-check.mjs",
    "market:build-db": "node scripts/run-python.mjs tools/build_market_research_db.py",
    "market:stats": "node scripts/run-python.mjs tools/query_market_research_db.py stats",
    "market:services": "node scripts/run-python.mjs tools/query_market_research_db.py services",
    "market:pains": "node scripts/run-python.mjs tools/query_market_research_db.py pains",
    "openapi:export": "node scripts/run-python.mjs tools/export_openapi.py",
    "openapi:types": "npm --prefix frontend run openapi:types",
    "openapi:sync": "npm run openapi:export && npm run openapi:types",
    "check:error-labels": "node scripts/check-error-labels.mjs",
    "check:diff": "git diff --check",
    "check": "npm run backend:lint && npm run backend:compile && npm run backend:test && npm run check:error-labels && npm run build && npm run test:ui && npm run check:diff"
  }
}
