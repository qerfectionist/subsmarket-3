# Backend
APP_ENV=development
# Managed Postgres URLs like postgresql://... are supported in production.
DATABASE_URL=postgresql+psycopg://subsmarket:subsmarket@localhost:5432/subsmarket
TELEGRAM_BOT_TOKEN=
TELEGRAM_MINI_APP_URL=http://localhost:5173
TELEGRAM_WEBHOOK_URL=http://localhost:8000/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=dev-telegram-webhook-secret-change-me
VITE_TELEGRAM_MINI_APP_LINK=https://t.me/subscription_market_bot
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false
PAYMENT_REQUISITE_SECRET=dev-payment-requisite-secret-change-me
INTERNAL_JOB_TOKEN=dev-internal-job-token-change-me
# Optional locally. Set in production when more than one backend instance runs.
RATE_LIMIT_REDIS_URL=
# Optional. Set in production to send backend exceptions to Sentry.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_RELEASE=
CORS_ALLOWED_ORIGINS=*
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_RETRY_BASE_SECONDS=60
NOTIFICATION_RETRY_MAX_SECONDS=3600
NOTIFICATION_DISPATCH_BATCH_SIZE=100
NOTIFICATION_DISPATCH_MAX_BATCHES=5
ACCESS_REMINDER_COOLDOWN_SECONDS=600
MARKETPLACE_GB_ENABLED=false
MARKETPLACE_ACCOUNTS_ENABLED=false
MARKETPLACE_ACCOUNT_LISTING_DAYS=30
MARKETPLACE_LISTING_DAYS=7
MARKETPLACE_LISTING_EXPIRY_REMINDER_DAYS=1
MARKETPLACE_REQUEST_REMINDER_DELAY_SECONDS=7200
MARKETPLACE_REQUEST_REMINDER_COOLDOWN_SECONDS=7200
JOB_BATCH_SIZE=200
JOB_MAX_BATCHES_PER_STEP=5
DEMO_TELEGRAM_USER_ID=100001
DEMO_TELEGRAM_USERNAME=demo_user
DEMO_TELEGRAM_FIRST_NAME=Demo
DEMO_ACTIVATE_CATALOG=true

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_SHOW_DEV_USER_SWITCH=false
