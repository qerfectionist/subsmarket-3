{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "subsmarket-jobs-scheduler",
  "main": "src/index.js",
  "compatibility_date": "2026-07-21",
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "vars": {
    "API_BASE_URL": "https://api.subsmarket.xyz"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
